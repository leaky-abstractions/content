{# Layout primitives. Importing macros here keeps section/back-link rendering
   in one place; if the prompt format or back-link wording changes, edit only
   this file. #}

{# Render a "fake terminal" cat <file>.md section.
   Use {% call catSection(...) %}body markdown here{% endcall %}.

   Args:
     path     virtual path shown before the prompt (e.g. "~", "~/episodes/foo")
     file     filename shown after `cat ` (e.g. "welcome.md", "intro.md")
     options  optional object:
                pagefind  if true, marks section for Pagefind indexing
                          and excludes the prompt line from the index
                body      class for the body div (default: "welcome").
                          Use "post-content" for full episode/page bodies.
#}
{% macro catSection(path, file, options={}) %}
<div class="section"{% if options.pagefind %} data-pagefind-body{% endif %}>
    <div class="prompt"{% if options.pagefind %} data-pagefind-ignore{% endif %}><span class="path">{{ path }}</span> <span class="dollar">$</span> cat {{ file }}</div>
    <div class="{{ options.body or 'welcome' }}">
        {{ caller() }}
    </div>
</div>
{% endmacro %}

{# Render the bottom-of-page "back" navigation link.
   Args:
     url    href to navigate to (already path-prefixed)
     label  link text (default: "cd ..")
#}
{% macro backLink(url, label='cd ..') %}
<div class="back-link">
    <a href="{{ url }}">&larr; {{ label }}</a>
</div>
{% endmacro %}

{# Render a YAML-frontmatter-style metadata block at the top of a post body.
   Designed to look like the file's actual frontmatter that `cat` would output.
   Each value reuses the existing color/badge vocabulary (.date, .reading-time,
   .tag, .tag.tag-count) so metadata reads consistently across the site.

   Args:
     date           yyyy-mm-dd string                    (optional)
     readingTime    integer minutes                      (optional)
     tags           array of strings                     (optional, omitted if empty)
     series         object { seriesSlug, index, total }  (optional)
                    Renders as one row: `series: [slug] [N of M]`
                    (cyan series tag + magenta position badge).
     author         object { name, url, email, icon }  (optional)
                    Renders as YAML-style author line:
                    `author: [icon] name <email>` with name+icon linking
                    to author.url and email as a mailto: link.
#}
{% macro frontmatterBlock(date=null, readingTime=null, tags=[], series=null, author=null) %}
<div class="frontmatter">
    <div class="fm-delim">---</div>
    {%- if author %}
    <div class="fm-row"><span class="fm-key">author:</span><span class="fm-author"><a href="{{ author.url }}" class="fm-author-link" rel="author"{% if author.url.startsWith('http') %} target="_blank" rel="noopener author"{% endif %}>{% if author.icon %}<i class="{{ author.icon }}"></i> {% endif %}<span class="link-text">{{ author.name }}</span></a>{% if author.email %} &lt;<a href="mailto:{{ author.email }}" class="fm-author-email"><span class="link-text">{{ author.email }}</span></a>&gt;{% endif %}</span></div>
    {%- endif %}
    {%- if date %}
    <div class="fm-row"><span class="fm-key">date:</span><span class="date">{{ date }}</span></div>
    {%- endif %}
    {%- if readingTime %}
    <div class="fm-row"><span class="fm-key">reading-time:</span><span class="reading-time">{{ readingTime }} min</span></div>
    {%- endif %}
    {%- if tags and tags.length %}
    <div class="fm-row"><span class="fm-key">tags:</span><span class="fm-tags">{% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}</span></div>
    {%- endif %}
    {%- if series %}
    <div class="fm-row"><span class="fm-key">series:</span><span class="fm-series"><span class="tag">{{ series.seriesSlug }}</span><span class="tag tag-count">{{ series.index }} of {{ series.total }}</span></span></div>
    {%- endif %}
    <div class="fm-delim">---</div>
</div>
{% endmacro %}
