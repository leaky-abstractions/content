---
title: Home
summary: "Software engineering, architecture and computer science deep dives. With a focus on game dev and embedded systems."
permalink: /index.html
virtualPath: "~"
---
{% from "post-card.njk" import postCard %}
{% from "macros.njk" import catSection %}

{% call catSection('~', 'welcome.md') %}{{ welcome | md | safe }}{% endcall %}

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls -t episodes/**/[0-9]*.md | head -5 <span class="prompt-comment"># latest episodes</span></div>
    {% for ep in latestEpisodes %}
    {{ postCard({
        kind: 'post',
        url: ep.url,
        title: ep.title,
        pathPrefix: ep.seriesSlug + '/' if ep.seriesSlug else null,
        date: ep.date,
        readingTime: ep.readingTime,
        summary: ep.summary,
        tags: ep.tags,
        seriesPosition: ep.seriesPosition
    }) }}
    {% endfor %}
</div>

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls links/ <span class="prompt-comment"># quick links</span></div>
    <div class="ls-output">
        {% for link in links %}
        <a href="{{ link.url }}" class="ls-entry ls-type-{{ link.type | default('file') }}{% if link.external %} ls-external{% endif %}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>{% if link.icon %}<i class="{{ link.icon }}"></i> {% endif %}<span class="link-text">{{ link.name }}</span></a>
        {% endfor %}
    </div>
</div>
