---
title: Home
summary: "Software engineering, architecture and computer science deep dives. With a focus on game dev and embedded systems."
permalink: /index.html
virtualPath: "~"
---
{% from "post-card.njk" import postCard %}
{% from "macros.njk" import catSection %}

{% call catSection('~', 'welcome.md') %}{{ welcome | md | safe }}{% endcall %}

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls -lt episodes/</div>
    {% for post in collections.standaloneEpisodes %}
    {{ postCard({
        kind: 'post',
        url: post.url,
        title: post.data.title,
        date: post.date | date,
        readingTime: post.data.readingTime,
        summary: post.data.summary,
        tags: post.data.tags
    }) }}
    {% endfor %}
    {% for series in allSeriesData %}
    {{ postCard({
        kind: 'series',
        url: series.url,
        title: series.slug + '/',
        date: series.episodes[series.episodes.length - 1].date if series.episodes.length else null,
        summary: series.description,
        episodeCount: series.episodes.length
    }) }}
    {% endfor %}
</div>

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls links/</div>
    <div class="ls-output">
        {% for link in links %}
        <a href="{{ link.url }}" class="ls-entry ls-type-{{ link.type | default('file') }}{% if link.external %} ls-external{% endif %}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>{% if link.icon %}<i class="{{ link.icon }}"></i> {% endif %}<span class="link-text">{{ link.name }}</span></a>
        {% endfor %}
    </div>
</div>
