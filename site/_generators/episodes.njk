---
title: Episodes
permalink: /episodes/index.html
virtualPath: "~/episodes"
---
{% from "post-card.njk" import postCard %}
{% from "macros.njk" import backLink %}

<div class="section">
    <div class="prompt"><span class="path">~/episodes</span> <span class="dollar">$</span> ls -lt</div>
    {% if collections.standaloneEpisodes.length or allSeriesData.length %}
    {% for post in collections.standaloneEpisodes %}
    {{ postCard({
        kind: 'post',
        url: post.url,
        title: post.data.title,
        date: post.date | date,
        readingTime: post.data.readingTime,
        summary: post.data.summary,
        tags: post.data.tags
    }) }}
    {% endfor %}
    {% for series in allSeriesData %}
    {{ postCard({
        kind: 'series',
        url: series.url,
        title: series.slug + '/',
        date: series.episodes[series.episodes.length - 1].date if series.episodes.length else null,
        summary: series.description,
        episodeCount: series.episodes.length
    }) }}
    {% endfor %}
    {% else %}
    <p>No episodes yet.</p>
    {% endif %}
</div>
{{ backLink(pathPrefix + '/') }}
