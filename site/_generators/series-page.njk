---
pagination:
    data: allSeriesData
    size: 1
    alias: seriesData
permalink: "/episodes/{{ seriesData.slug }}/index.html"
layout: base.njk
eleventyComputed:
    title: "{{ seriesData.title }}"
    summary: "{{ seriesData.description }}"
    virtualPath: "~/episodes/{{ seriesData.slug }}"
---

<div class="section">
    <div class="prompt"><span class="path">~/episodes/{{ seriesData.slug }}</span> <span class="dollar">$</span> cat README.md</div>
    <div class="welcome">{{ seriesData.readme | md | safe }}</div>
</div>

<div class="section">
    <div class="prompt"><span class="path">~/episodes/{{ seriesData.slug }}</span> <span class="dollar">$</span> ls -lt</div>
    {% if seriesData.episodes.length %}
    {% for ep in seriesData.episodes %}
    <div class="post">
        <div class="post-title">
            <a href="{{ ep.url }}"><i class="fa-brands fa-markdown"></i> <span class="link-text">{{ ep.title }}</span></a>
        </div>
        <div class="post-meta">
            <span class="date">{{ ep.date }}</span> — {{ ep.summary }}{% for tag in ep.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
        </div>
    </div>
    {% endfor %}
    {% else %}
    <p>No episodes yet.</p>
    {% endif %}
</div>
<div class="back-link">
    <a href="{{ pathPrefix }}/episodes/">&larr; cd ..</a>
</div>
