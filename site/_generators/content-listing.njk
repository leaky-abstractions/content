---
pagination:
    data: contentListings
    size: 1
    alias: listing
permalink: "/{{ listing.dirName }}/index.html"
layout: base.njk
eleventyComputed:
    title: "{{ listing.dirName }}"
    virtualPath: "~/{{ listing.dirName }}"
---
{% from "post-card.njk" import postCard %}
{% from "macros.njk" import catSection, backLink %}

{% if listing.readme | length %}
{% call catSection('~/' + listing.dirName, 'README.md') %}{{ listing.readme | md | safe }}{% endcall %}
{% endif %}

<div class="section">
    <div class="prompt"><span class="path">~/{{ listing.dirName }}</span> <span class="dollar">$</span> ls -lt</div>
    {% for page in listing.pages %}
    {{ postCard({
        kind: 'post',
        url: page.url,
        title: page.title,
        date: page.date,
        readingTime: page.readingTime,
        summary: page.summary,
        tags: page.tags
    }) }}
    {% endfor %}
</div>
{{ backLink(pathPrefix + '/') }}
