{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "channel.schema.json",
    "title": "Channel-level metadata",
    "$defs": {
        "keywords": {
            "type": "object",
            "properties": {
                "keywords": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1
                }
            },
            "required": ["keywords"],
            "additionalProperties": false
        }
    }
}
